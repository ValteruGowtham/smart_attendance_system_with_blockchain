# Django Configuration
DJANGO_SECRET_KEY=django-insecure-deploy-key-change-in-production-12345678901234567890
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,backend

# Database Configuration
DATABASE_URL=postgresql://attendance_user:attendance_pass123@db:5432/attendance_db

# Blockchain Configuration (Ganache)
GANACHE_URL=http://ganache:8545
GANACHE_NETWORK_ID=5777
CONTRACT_ADDRESS=0xDa0c9a811f7851Deb38A66889D5510789DbBCd05

# Redis Configuration
REDIS_URL=redis://redis:6379/0

# ==================== EMAIL CONFIGURATION ====================
# Gmail SMTP settings
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=your-email@gmail.com

# ==================== CELERY CONFIGURATION ====================
# Celery broker and result backend (Redis)
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# ==================== SMS SERVICE CONFIGURATION (OPTIONAL) ====================
# Enable SMS service
SMS_SERVICE_ENABLED=False
SMS_PROVIDER=twilio

# Twilio Configuration
TWILIO_ACCOUNT_SID=your-account-sid
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# Nexmo/Vonage Configuration (Alternative to Twilio)
NEXMO_API_KEY=your-api-key
NEXMO_API_SECRET=your-api-secret

# Security Settings
SECURE_SSL_REDIRECT=False
SECURE_HSTS_SECONDS=0
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False

# File Upload Settings
MEDIA_URL=/media/
STATIC_URL=/static/
MEDIA_ROOT=/app/media
STATIC_ROOT=/app/staticfiles